# Copy this file to `.env` and fill in values.
# Never commit real credentials to the repository.

# --- Runtime ---
LLM_BACKEND=ollama
OLLAMA_MODEL=llama3.2:1b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
AGENT_MODE=local
# AGENT_MODE options: "local" (use Bedrock directly) or "agentcore" (use AgentCore service)
# Note: Use "agentcore" only after fully configuring all AGENTCORE_* variables above

# AgentCore (only needed when AGENT_MODE=agentcore)
# Get these values from AWS Bedrock console:
# - AGENTCORE_AGENT_ID: Agent ID (e.g., P588RSXHV0)
# - AGENTCORE_ALIAS_ID: Alias/Version ID (e.g., PJFJLDGKGC) - REQUIRED!
# - AGENTCORE_RUNTIME_ARN: Full runtime ARN (arn:aws:bedrock-agentcore:...)
# - AGENTCORE_MEMORY_ID: Memory ID created for the agent (optional)
AGENTCORE_RUNTIME_ARN=
AGENTCORE_AGENT_ID=
AGENTCORE_ALIAS_ID=
AGENTCORE_MEMORY_ID=

# --- AWS (use standard AWS_* env vars for creds; do not hardcode) ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

S3_BUCKET_REPORTS=research-agent-reports
S3_BUCKET_PDFS=research-agent-pdfs
S3_BUCKET_EXPORTS=research-agent-exports

TABLE_SESSIONS=research-agent-sessions
TABLE_SOURCES=research-agent-sources
TABLE_HYPOTHESES=research-agent-hypotheses
TABLE_CONTRADICTIONS=research-agent-contradictions
TABLE_LIVING_DOC_CHECKS=research-agent-living-doc-checks

LOG_GROUP_NAME=/research-agent
METRICS_NAMESPACE=ResearchAgent

# Optional: enable backend event payload capture (defaults to false)
BACKEND_EVENTS_LOG_PATH=logs/backend_events.jsonl
BACKEND_LOG_INCLUDE_CONTENT=false

# Retrieval stage hard limits to avoid hanging runs
RETRIEVER_PARALLEL_TIMEOUT_SECONDS=45
RETRIEVER_PDF_ENRICH_MAX_SECONDS=60
RETRIEVER_EMBEDDING_MAX_SECONDS=60
RETRIEVER_MAX_PDF_ITEMS=8
RETRIEVER_MAX_EMBED_ITEMS=12

# Contradiction detector guardrails to avoid long mid-run stalls
CONTRADICTION_MAX_SOURCES=6
CONTRADICTION_MAX_CLAIMS_PER_SOURCE=5
CONTRADICTION_MAX_CANDIDATE_PAIRS=30
CONTRADICTION_MAX_ANALYSIS_PAIRS=12
CONTRADICTION_MAX_STAGE_SECONDS=180
CONTRADICTION_SOURCE_CONTENT_MAX_CHARS=3000

# Optional: Langfuse (leave blank if unused)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
